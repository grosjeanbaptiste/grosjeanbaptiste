            url "https://www.acteble.com"
            location t{ en: "Brussels, Belgium", fr: "Bruxelles, Belgique", nl: "Brussel, België", es: "Bruselas, Bélgica", de: "Brüssel, Belgien", zh: "布鲁塞尔，比利时" }
            period 2025-07-01..present
            summary t{ en: "Sole founder, architect and developer. Rust backend + Flutter mobile. The R&D layer doubles as the dissertation for my MSc in Computer Science at UMons.", fr: "Fondateur unique, architecte et développeur. Backend Rust + mobile Flutter. La couche R&D tient lieu de mémoire dans le cadre de mon Master en sciences informatiques à l'UMons.", nl: "Enige oprichter, architect en ontwikkelaar. Rust-backend + Flutter-mobile. De R&D-laag dient als mijn masterthesis voor de master in de computerwetenschappen aan UMons.", es: "Fundador único, arquitecto y desarrollador. Backend en Rust + móvil en Flutter. La capa de I+D sirve como memoria de fin de máster en el marco de mi máster en ciencias informáticas en UMons.", de: "Alleiniger Gründer, Architekt und Entwickler. Rust-Backend + Flutter-Mobile. Die F&E-Schicht dient gleichzeitig als Masterarbeit für meinen MSc in Informatik an der UMons.", zh: "唯一的创始人、架构师和开发者。Rust 后端 + Flutter 移动端。研发层同时作为蒙斯大学 (UMons) 计算机科学硕士论文的研究内容。" }
            uses [Rust, Flutter, Dart, Tokio, Docker, DDD, CleanArchitecture]
