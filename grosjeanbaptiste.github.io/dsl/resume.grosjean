        soft [Adaptability, Resilience, Leadership, Creativity, Initiative, Analysis, Flexibility, Teamwork, Organization, Pragmatism, Resourcefulness, Thoroughness]
    }

    // ---------- languages ----------
    languages {
        French {
            language t{ en: "French", fr: "Français", nl: "Frans", es: "Francés", de: "Französisch", zh: "法语" }
            fluency t{ en: "Native Speaker", fr: "Langue maternelle", nl: "Moedertaal", es: "Lengua materna", de: "Muttersprache", zh: "母语" }
        }
        English {
            language t{ en: "English", fr: "Anglais", nl: "Engels", es: "Inglés", de: "Englisch", zh: "英语" }
            fluency t{ en: "B1+/B2 (TOEIC 730/ ELAO)", fr: "B1+/B2 (TOEIC 730 / ELAO)", nl: "B1+/B2 (TOEIC 730 / ELAO)", es: "B1+/B2 (TOEIC 730 / ELAO)", de: "B1+/B2 (TOEIC 730 / ELAO)", zh: "B1+/B2 (TOEIC 730 / ELAO)" }
        }
        Dutch {
            language t{ en: "Dutch", fr: "Néerlandais", nl: "Nederlands", es: "Neerlandés", de: "Niederländisch", zh: "荷兰语" }
            fluency t{ en: "B1", fr: "B1", nl: "B1", es: "B1", de: "B1", zh: "B1" }
        }
    }

    // ---------- competitions ----------
    competitions {
        HackathonCOW2024 {
            title t{ en: "Hackathon Citizens of Wallonia 2024", fr: "Hackathon Citizens of Wallonia 2024", nl: "Hackathon Citizens of Wallonia 2024", es: "Hackathon Citizens of Wallonia 2024", de: "Hackathon Citizens of Wallonia 2024", zh: "Hackathon Citizens of Wallonia 2024" }
            date 2024-03-17
            organizer t{ en: "Citizens of Wallonia", fr: "Citizens of Wallonia", nl: "Citizens of Wallonia", es: "Citizens of Wallonia", de: "Citizens of Wallonia", zh: "Citizens of Wallonia" }
            url "https://www.cow.be"
            summary t{ en: "EduCraft — solution allowing anyone to craft a personalized path to gain new skills.", fr: "EduCraft — solution permettant à chacun de tracer son propre parcours personnalisé d'acquisition de compétences.", nl: "EduCraft — oplossing waarmee iedereen een eigen gepersonaliseerd leerpad kan opstellen om nieuwe vaardigheden te verwerven.", es: "EduCraft — solución que permite a cualquiera diseñar su propio itinerario personalizado para adquirir nuevas competencias.", de: "EduCraft — Lösung, mit der jeder seinen eigenen personalisierten Weg zum Erwerb neuer Fähigkeiten gestalten kann.", zh: "EduCraft — 让任何人都能定制个性化路径以获得新技能的解决方案。" }
        }
        HackathonCOW2023 {
            title t{ en: "Hackathon Citizens of Wallonia 2023", fr: "Hackathon Citizens of Wallonia 2023", nl: "Hackathon Citizens of Wallonia 2023", es: "Hackathon Citizens of Wallonia 2023", de: "Hackathon Citizens of Wallonia 2023", zh: "Hackathon Citizens of Wallonia 2023" }
            date 2023-03-31
            organizer t{ en: "Citizens of Wallonia", fr: "Citizens of Wallonia", nl: "Citizens of Wallonia", es: "Citizens of Wallonia", de: "Citizens of Wallonia", zh: "Citizens of Wallonia" }
            url "https://www.cow.be"
            summary t{ en: "OnlyTogether — solution ensuring vulnerable users are always accompanied.", fr: "OnlyTogether — solution assurant que les utilisateurs vulnérables soient toujours accompagnés.", nl: "OnlyTogether — oplossing die ervoor zorgt dat kwetsbare gebruikers altijd begeleid worden.", es: "OnlyTogether — solución que garantiza que los usuarios vulnerables estén siempre acompañados.", de: "OnlyTogether — Lösung, die sicherstellt, dass schutzbedürftige Nutzer immer begleitet werden.", zh: "OnlyTogether — 确保弱势用户始终有人陪伴的解决方案。" }
        }
    }

    // ---------- awards ----------
    awards {
        TOEIC {
            title t{ en: "TOEIC", fr: "TOEIC", nl: "TOEIC", es: "TOEIC", de: "TOEIC", zh: "TOEIC" }
            date 2023-06-06
            awarder t{ en: "ETS", fr: "ETS", nl: "ETS", es: "ETS", de: "ETS", zh: "ETS" }
            summary t{ en: "730", fr: "730", nl: "730", es: "730", de: "730", zh: "730" }
        }
    }

    // ---------- interests ----------
    interests {
        ResearchAndDevelopment {
            name t{ en: "Research and Development", fr: "Recherche et développement", nl: "Onderzoek en ontwikkeling", es: "Investigación y desarrollo", de: "Forschung und Entwicklung", zh: "研究与开发" }
            keywords ["Innovations", "Experimentation", "POCs"]
        }
    }

    // ---------- volunteer ----------
    volunteer {
        StudentRepresentative {
            position t{ en: "Student Representative", fr: "Délégué étudiant", nl: "Studentenvertegenwoordiger", es: "Delegado de estudiantes", de: "Studierendenvertreter", zh: "学生代表" }
            organization "UMons"
            url "https://www.umons.be"
            period 2023-11-30..present
        }
        BuddyTandemons {
            position t{ en: "Buddy Tandemons", fr: "Buddy TandeMons", nl: "Buddy TandeMons", es: "Buddy TandeMons", de: "Buddy TandeMons", zh: "Buddy TandeMons" }
            organization "UMons"
            url "https://www.umons.be"
            period 2023-11-30..present
        }
        StudentRepresentative2 {
            position t{ en: "Student Representative", fr: "Délégué étudiant", nl: "Studentenvertegenwoordiger", es: "Delegado de estudiantes", de: "Studierendenvertreter", zh: "学生代表" }
            organization "EPHEC École Supérieure de Promotion Sociale"
            url "https://www.ephec.be"
            period 2019-09-30..2022-10-15
        }
        Tutor {
            position t{ en: "Tutor", fr: "Tuteur", nl: "Tutor", es: "Tutor", de: "Tutor", zh: "辅导员" }
            organization "EPHEC École Supérieure de Promotion Sociale"
            url "https://www.ephec.be"
            period 2019-09-30..2022-10-15
        }
    }

    // ---------- meta ----------
    meta {
        theme "kendall"
        brand {
            // Shared brand (HTML + favicon + manifest + accent across all views)
            primary "#800020"
            accent "#F3890B"
            darkBg "#121212"

            // HTML site palette (variables.css)
            siteSecondary "#ff0000"
            siteBody "#666666"
            siteEmphasis "#2e2e2e"
            siteBg "#e2e2e2"
            siteCard "#ffffff"
            siteBorder "#dddddd"
            sitePrimaryDark "#ff4d6d"
            siteSecondaryDark "#ff6b6b"
            siteAccentDark "#ffb347"
            siteBodyDark "#cccccc"
            siteEmphasisDark "#e0e0e0"
            siteCardDark "#1e1e1e"
            siteBorderDark "#333333"

            // XSLT palette (rich + minimal :root)
            xsltPrimary "#001F5A"
            xsltBody "#2E2E2E"
            xsltMuted "#666"
            xsltBg "#ffffff"
            xsltRuleLight "#E2E2E2"
            xsltRuleRich "#ddd"
            xsltBlockMin "#555"
            xsltTbBg "#F7F7F7"
            xsltPrimaryDark "#FFB142"
            xsltBodyDark "#EDE0C8"
            xsltMutedDark "#B89A82"
            xsltBgDark "#1F0E0E"
            xsltSidebarDark "#2E1818"
            xsltRuleDark "#4A2828"
            xsltBlockMinDark "#D4C0A0"

            // Font stacks
            fontXslt "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif"
            fontSite "'Roboto', sans-serif"
        }
        sectionOrder [about work education skills languages dailyLife awards interests references]
        sidebarOrder [languages projects skills dailyLife]
        dailyLife {
            sleep 8 color "#F3890B"
            transport 2 color "#FF0000"
            work 9 color "#001F5A"
            classes 3 color "#C0C0C0"
            sport 1 color "#008000"
            others 5 color "#FFFF00"
        }
    }

}
